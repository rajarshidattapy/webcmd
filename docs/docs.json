{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Webcmd",
  "description": "An agent runtime for turning websites, apps, APIs, and local tools into deterministic CLIs.",
  "colors": {
    "primary": "#006B9A",
    "light": "#56C5FF",
    "dark": "#006B9A"
  },
  "logo": {
    "light": "/webcmd-logo-light.svg",
    "dark": "/webcmd-logo-dark.svg",
    "href": "https://webcmd.dev"
  },
  "favicon": "/webcmd.svg",
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#F8F6F1",
      "dark": "#0F0F0F"
    }
  },
  "fonts": {
    "heading": {
      "family": "Newsreader",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "agent-prompts"
            ]
          },
          {
            "group": "Understand Webcmd",
            "pages": [
              "concepts",
              "authentication-and-profiles",
              "local-or-cloud",
              "browser-and-sitemap-memory",
              "skills"
            ]
          },
          {
            "group": "Build and Share",
            "pages": [
              "authoring",
              "create-plugin",
              "publish-community-plugin"
            ]
          },
          {
            "group": "Use Cases",
            "pages": [
              "x-session-cli"
            ]
          },
          {
            "group": "Reference and Support",
            "pages": [
              "cli-reference",
              "troubleshooting"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/agent-runtime",
      "destination": "/concepts"
    },
    {
      "source": "/generated-clis",
      "destination": "/authoring"
    },
    {
      "source": "/plugins-and-skills",
      "destination": "/skills"
    }
  ]
}
